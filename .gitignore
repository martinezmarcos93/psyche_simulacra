# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# Distribución / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Entornos virtuales
.venv/
venv/
env/
ENV/

# ── Pytest / Coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ── Proyecto — datos generados en runtime ────────────────────────────────────
data/db/*.db
data/db/*.db-shm
data/db/*.db-wal
data/checkpoints/
data/exports/
data/sessions/

# Archivos de simulaciones archivadas (pueden ser >100 MB)
data/archive/**/simulation.db
data/archive/**/checkpoint_*.json

# Semillas iniciales SÍ se versionan (son configuración, no datos)
!data/seeds/

# ── Vault de Obsidian — contenido generado por simulación ────────────────────
# Los .md de personas/tribus/colectivo son output de runtime, no código fuente
vault/Personas/
vault/Tribus/
vault/Colectivo/
vault/Meta/
# La config de Obsidian sí se versiona (estructura del workspace)
!vault/.obsidian/

# ── Métricas de runtime ───────────────────────────────────────────────────────
data/metrics/

# ── IDE / editores ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Sistema operativo ─────────────────────────────────────────────────────────
# Windows
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Variables de entorno ──────────────────────────────────────────────────────
.env
.env.local
*.env

# ── Jupyter (por si se usan notebooks de análisis) ───────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Mypy / Ruff / linters ────────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/

# ── Documentos privados de diseño ────────────────────────────────────────────
_privado/
_PRIVADO*/
NOTAS_*.md
_notas*.md
