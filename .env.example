# ── Narrador (Ollama) ─────────────────────────────────────────────────────────
# Activar/desactivar generación narrativa con LLM (1 = activo, 0 = desactivado)
NARRATIVE_ENABLED=1

# URL base del servidor Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Modelo a usar (debe estar disponible en tu instancia de Ollama)
# Para descargarlo: ollama pull llama3.2
OLLAMA_MODEL=llama3.2

# Timeout en segundos para llamadas al LLM
OLLAMA_TIMEOUT=120

# ── Zona Liminal ─────────────────────────────────────────────────────────────
# Host del servidor liminal. 'localhost' para servidor local, IP para remoto
LIMINAL_HOST=localhost

# ── Simulación ────────────────────────────────────────────────────────────────
# Cada cuántos días simulados guardar un checkpoint automático
CHECKPOINT_INTERVAL=10

# Cada cuántos días simulados recalcular las tribus (clustering social)
DAYS_UNTIL_CLUSTERING=30
